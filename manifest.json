{
  "manifest_version": 3,
  "name": "Shuffle Tabs",
  "version": "1.12.0",
  "action": {
    "default_title": "Click to shuffle",
    "default_popup": "popup.html"
  },
  "permissions": ["alarms", "activeTab", "tabs", "storage", "scripting", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "shuffleTabs": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Command+MacCtrl+A"
      },
      "description": "Combination to shuffle tabs"
    },
    "snoozeTab": {
      "suggested_key": {
        "default": "Alt+Z",
        "mac": "Command+MacCtrl+Z"
      },
      "description": "Combination to snooze a single tab"
    },
    "altSnooze": {
      "suggested_key": {
        "mac": "Command+MacCtrl+S"
      },
      "description": "Combination to snooze a single tab"
    }
  },
  "description": "Extension to shuffle and snooze tabs"
}
