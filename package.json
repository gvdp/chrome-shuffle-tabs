{
  "name": "chrome-shuffle-tabs",
  "version": "1.14.1",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "lint": "concurrently -n lint \"pnpm:lint:*(!fix)\"",
    "lint:fix": "concurrently -n lint-fix \"pnpm:lint:*:fix\"",
    "lint:format": "prettier --check .",
    "lint:format:fix": "prettier --write .",
    "lint:js": "eslint . --cache",
    "lint:ts": "tsc --noEmit",
    "prepare": "husky install",
    "release": "npx standard-version",
    "start": "DEV=true vite dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.1",
    "@eslint/js": "10.0.1",
    "@types/chrome": "0.2.2",
    "@types/node": "25.9.5",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "happy-dom": "20.10.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "sinon": "22.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ],
    "*.js,*.ts": "eslint --cache --fix"
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "8.11.0"
  },
  "dependencies": {
    "vite": "8.1.4",
    "webextension-polyfill": "0.12.0"
  }
}
